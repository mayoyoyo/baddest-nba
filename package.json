{
  "name": "baddest-nba",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx --env-file=.env.local --watch src/server/node.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/server/node.js",
    "seed": "tsx --env-file=.env.local scripts/seed-nba-players.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "hono": "^4.7.7",
    "pg": "^8.16.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^29.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.4"
  }
}
