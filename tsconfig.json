{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": [
      "node",
      "vitest/globals",
      "@cloudflare/vitest-pool-workers/types"
    ]
  },
  "include": [
    "worker-configuration.d.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "functions/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.integration.config.ts",
    "playwright.config.ts"
  ]
}
